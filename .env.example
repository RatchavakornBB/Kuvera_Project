# Copy to .env and fill in. Never commit .env — it's gitignored.

# Required
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=

# Optional — multi-provider model_id support (Section 5.1) / voice intake
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPGRAM_API_KEY=

# SUPABASE_URL / SUPABASE_KEY: local values printed by `supabase start`
# (API URL and anon key), or your Supabase cloud project's values for
# an optional Phase 5 deploy.
# DATABASE_URL: the direct Postgres connection string, also from
# `supabase start`'s DB_URL — used only by the LangGraph Postgres
# Checkpointer (AGENT.md Section 1: Postgres checkpointer from day one,
# never an in-memory one), not by the app's regular Supabase client.
